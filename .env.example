DB_HOST=db
DB_PORT=5432
DB_NAME=howmanyareplaying
DB_USER=hmapuser
DB_PASSWORD=CHANGE_ME

PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://howmanyareplaying.com

STEAM_API_KEY=

VITE_API_BASE_URL=/api

# Admin dashboard auth
# Bcrypt hash of admin password (generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))")
ADMIN_PASSWORD_HASH=
# Example: ADMIN_PASSWORD=shanety  (do NOT put the raw password in production .env; use the hash above)

# Session secret for admin cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=
